# LLM Server (Qwen3.5-122B-A10B via llama.cpp)
# Thinking toggled per-request via chat_template_kwargs
LLAMA_URL=http://your-llm-host:3101
# Embedding model
LLAMA_EMBED_URL=http://your-llm-host:3103

# Logging
# "json" for Grafana Loki, "pretty" for development
LOG_FORMAT=pretty
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_PASSWORD=spin-cycle-dev

# News/search APIs (for evidence gathering)
# Get a key at: https://newsapi.org/
NEWSAPI_KEY=
# Get a key at: https://serper.dev/
SERPER_API_KEY=
# Get a key at: https://legiscan.com/legiscan
LEGISCAN_API_KEY=
